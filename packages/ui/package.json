{
  "name": "@conduit/ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Axiom design system — Tailwind preset, base tokens, and shared React primitives for Conduit/Axiom surfaces.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "styles",
    "tailwind.preset.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tailwind.preset": "./tailwind.preset.js",
    "./styles/tokens.css": "./styles/tokens.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.441.0"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.3"
  }
}
