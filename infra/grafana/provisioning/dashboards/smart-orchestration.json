    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "DAG and non-DAG FETCH_DATA traffic rates. Non-DAG is computed from FETCH_DATA minus DAG plans.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(conduit_dag_plan_total[$__rate_interval])) or vector(0)",
          "legendFormat": "multi-step",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "clamp_min(sum(rate(chat_intent_total{type=\"FETCH_DATA\"}[$__rate_interval])) - (sum(rate(conduit_dag_plan_total[$__rate_interval])) or vector(0)), 0)",
          "legendFormat": "single-step",
          "refId": "B"
        }
      ],
      "title": "Multi-step vs single-step traffic",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Distribution of DAG plan node counts, sourced from the node_count tag on conduit.dag.plan.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "id": 6,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 12,
        "minVizWidth": 8,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (node_count) (increase(conduit_dag_plan_total[$__range]))",
          "instant": true,
          "legendFormat": "{{node_count}} nodes",
          "refId": "A"
        }
      ],
      "title": "Fan-out depth / node count",
      "type": "bargauge"
    },
    {
      "datasource": {
