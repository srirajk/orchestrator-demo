    {
      "id": 11,
      "type": "row",
      "title": "Resilience \u2014 deadline, cancellation, honest outcomes",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Resilience: Cancellations",
      "description": "A request that exceeds conduit.request.deadline-ms, or whose client disconnects, is now CANCELLED \u2014 the pipeline stops calling the LLM and the agents. Before this existed, both kept running for a client that would never see the answer. A non-zero client_disconnect rate is normal (users close tabs); a rising deadline rate means requests are too slow.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 30
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(conduit_request_cancelled_total[$__rate_interval])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Request Outcomes (honest)",
      "description": "ANSWERED / CLARIFIED / DENIED / FAILED / ERROR. FAILED means agents were dispatched and none succeeded \u2014 such a request used to be recorded as ANSWERED, so this board (and eval, and audit) reported success for a request that returned zero data.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 30
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(conduit_request_outcome_total[$__rate_interval])) by (outcome)",
          "legendFormat": "{{outcome}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Zero-data + Partial answers",
      "description": "no_data is the metric to alert on: the user got prose, but not one byte of domain data.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 38
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(conduit_request_no_data_total[$__rate_interval]))",
          "legendFormat": "no_data (every agent failed)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "sum(rate(conduit_request_partial_total[$__rate_interval]))",
          "legendFormat": "partial (a sibling agent failed)",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Trace write (off the request path)",
      "description": "Trace events are buffered per request and flushed once, asynchronously, on a bounded queue. A non-zero dropped rate means the queue overflowed \u2014 a silent drop would be a lie, so it is counted. Queue depth persistently > 0 means the writer cannot keep up.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 38
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(conduit_trace_flushed_total[$__rate_interval]))",
          "legendFormat": "flushed/s",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "sum(rate(conduit_trace_dropped_total[$__rate_interval]))",
          "legendFormat": "DROPPED/s",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "max(conduit_trace_queue_depth)",
          "legendFormat": "queue depth",
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    }
