    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Real-time status of all 9 data agents. CB State: CLOSED = healthy, HALF_OPEN = recovering, OPEN = circuit tripped (failing fast). Error % and p95 latency help SREs spot degraded agents before the circuit opens.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "left",
            "displayMode": "auto",
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "CB State"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": {"color": "green", "index": 0, "text": "CLOSED"},
                      "1": {"color": "yellow", "index": 1, "text": "HALF_OPEN"},
                      "2": {"color": "red", "index": 2, "text": "OPEN"}
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Error %"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "yellow", "value": 5},
                    {"color": "red", "value": 15}
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "p95 ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "yellow", "value": 1000},
                    {"color": "red", "value": 3000}
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Calls / min"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "custom.width",
                "value": 110
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Agent"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 300
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "id": 30,
      "options": {
        "footer": {
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Agent",
            "desc": false
          }
        ]
      },
      "title": "Agent Status — All 9 Agents",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "conduit_circuit_breaker_state",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(conduit_agent_calls_total[1m]) * 60",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * (sum by (agentId) (rate(conduit_agent_calls_total{status!=\"OK\"}[$__range])) or (sum by (agentId) (rate(conduit_agent_calls_total[$__range])) * 0)) / clamp_min(sum by (agentId) (rate(conduit_agent_calls_total[$__range])), 1e-9)",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (agentId, le) (rate(conduit_agent_latency_seconds_bucket[$__range]))) * 1000",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "D"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "agentId",
                "Value #A",
                "Value #B",
                "Value #C",
                "Value #D"
              ]
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "agentId": "Agent",
              "Value #A": "CB State",
              "Value #B": "Calls / min",
              "Value #C": "Error %",
              "Value #D": "p95 ms"
            }
          }
        }
      ]
    },
