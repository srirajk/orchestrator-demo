{
  "__inputs": [],
  "__requires": [],
  "annotations": {"list": []},
  "description": "Conduit AI Gateway — request throughput, latency percentiles, intent distribution, agent call health",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["conduit", "performance"],
  "templating": {
    "list": [
      {
        "current": {"value": "5m"},
        "hide": 0,
        "label": "Rate Window",
        "name": "rate_window",
        "options": [
          {"selected": false, "text": "1m", "value": "1m"},
          {"selected": true,  "text": "5m", "value": "5m"},
          {"selected": false, "text": "10m","value": "10m"}
        ],
        "query": "1m,5m,10m",
        "type": "custom"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Conduit Gateway — Performance",
  "uid": "conduit-perf",
  "version": 1,
  "panels": [

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Throughput & Errors",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "errors"},
            "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 2,
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"conduit-gateway\", uri=\"/v1/chat/completions\", outcome=\"SUCCESS\"}[$rate_window]))",
          "legendFormat": "success"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"conduit-gateway\", uri=\"/v1/chat/completions\", outcome!=\"SUCCESS\"}[$rate_window]))",
          "legendFormat": "errors"
        }
      ],
      "title": "Chat Completions — Request Rate",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 15}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"conduit-gateway\", uri=\"/v1/chat/completions\"}[$rate_window])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"conduit-gateway\", uri=\"/v1/chat/completions\"}[$rate_window])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"conduit-gateway\", uri=\"/v1/chat/completions\"}[$rate_window])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "title": "Chat Completions — Latency (p50 / p95 / p99)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 10,
      "title": "Intent Classification",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 11,
      "targets": [
        {
          "expr": "sum(rate(chat_intent_total{job=\"conduit-gateway\"}[$rate_window])) by (intent)",
          "legendFormat": "{{intent}}"
        }
      ],
      "title": "Intent Distribution — by Type",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "id": 12,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(intent_classify_duration_seconds_bucket{job=\"conduit-gateway\"}[$rate_window])) by (le))",
          "legendFormat": "classify p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(intent_classify_duration_seconds_bucket{job=\"conduit-gateway\"}[$rate_window])) by (le))",
          "legendFormat": "classify p95"
        }
      ],
      "title": "Intent Classify Latency (p50 / p95)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 20,
      "title": "Outbound Agent Calls",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": ".*error.*"},
            "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 21,
      "targets": [
        {
          "expr": "sum(rate(http_client_requests_seconds_count{job=\"conduit-gateway\", outcome=\"SUCCESS\"}[$rate_window])) by (client_name, uri)",
          "legendFormat": "{{client_name}} {{uri}}"
        },
        {
          "expr": "sum(rate(http_client_requests_seconds_count{job=\"conduit-gateway\", outcome!=\"SUCCESS\"}[$rate_window])) by (client_name, uri)",
          "legendFormat": "ERROR {{client_name}} {{uri}}"
        }
      ],
      "title": "Outbound Calls — Request Rate (by target)",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "id": 22,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_client_requests_seconds_bucket{job=\"conduit-gateway\"}[$rate_window])) by (le, client_name))",
          "legendFormat": "{{client_name}} p95"
        }
      ],
      "title": "Outbound Calls — p95 Latency (by target)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "id": 30,
      "title": "Stat Summaries",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 28},
      "id": 31,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "expr": "sum(increase(http_server_requests_seconds_count{job=\"conduit-gateway\", uri=\"/v1/chat/completions\"}[1h]))",
          "legendFormat": "Total Requests (1h)"
        }
      ],
      "title": "Requests (last 1h)",
      "type": "stat"
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.9},
            {"color": "green", "value": 0.99}
          ]}
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 28},
      "id": 32,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"conduit-gateway\", uri=\"/v1/chat/completions\", outcome=\"SUCCESS\"}[$rate_window])) / sum(rate(http_server_requests_seconds_count{job=\"conduit-gateway\", uri=\"/v1/chat/completions\"}[$rate_window]))",
          "legendFormat": "Success Rate"
        }
      ],
      "title": "Success Rate",
      "type": "stat"
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "s", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 10},
            {"color": "red", "value": 20}
          ]}
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 28},
      "id": 33,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"conduit-gateway\", uri=\"/v1/chat/completions\"}[$rate_window])) by (le))",
          "legendFormat": "p99 Latency"
        }
      ],
      "title": "p99 Latency",
      "type": "stat"
    }
  ]
}
