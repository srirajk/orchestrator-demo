  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "### Conduit \u2014 Platform 2 \u00b7 Internals & Infra\n**What's under the hood?** The infrastructure and internal signals behind the product health on **Platform 1**: JVM & container resources, long-conversation memory compaction, the Cerbos authorization gate, per-agent circuit breakers and up/down for every platform dependency."
      }
    },
    {
      "id": 2,
      "type": "row",
      "title": "Resources \u2014 gateway JVM, containers, Redis",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 3
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Gateway JVM heap",
      "description": "Gateway heap used vs max. Sustained used\u2192max means GC pressure.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "jvm_memory_used_bytes{job=\"conduit-gateway\", area=\"heap\"}",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "jvm_memory_max_bytes{job=\"conduit-gateway\", area=\"heap\"}",
          "legendFormat": "max",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Gateway JVM threads",
      "description": "Live / daemon / peak platform threads (virtual threads carry the fan-out and are not counted here).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "jvm_threads_live_threads{job=\"conduit-gateway\"}",
          "legendFormat": "live",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "jvm_threads_daemon_threads{job=\"conduit-gateway\"}",
          "legendFormat": "daemon",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "jvm_threads_peak_threads{job=\"conduit-gateway\"}",
          "legendFormat": "peak",
          "refId": "C"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Redis (Lettuce) command latency",
      "description": "Mean vs max Redis command completion time. Redis backs routing (RediSearch) and session state.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(lettuce_command_completion_seconds_sum[5m]))/sum(rate(lettuce_command_completion_seconds_count[5m]))",
          "legendFormat": "avg",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max(lettuce_command_completion_seconds_max)",
          "legendFormat": "max",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "All-container CPU",
      "description": "Aggregate CPU across all Conduit Docker containers (cAdvisor exposes only cgroup ids on this host, so per-service split is not available).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(container_cpu_usage_seconds_total{id=~\"/docker/.+\"}[5m])) * 100",
          "legendFormat": "cores %",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "All-container memory",
      "description": "Aggregate RSS across all Conduit Docker containers (host-level cAdvisor limitation \u2014 no per-service label).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(container_memory_usage_bytes{id=~\"/docker/.+\"})",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 8,
      "type": "row",
      "title": "Memory & Compaction \u2014 long-conversation guardrail",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 19
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Summary-attached guardrail",
      "description": "Fraction of turns that carried a compaction summary over a generous 6h window. This is a GUARDRAIL, not a target: any nonzero value is GREEN/healthy, because only long conversations need a summary and most turns are short. Only a sustained EXACTLY 0 (no summary attached anywhere in 6h of use) reads red \u2014 the silent-compaction-breakage signal.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0.0001
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(chat_compaction_summary_attached_total{attached=\"true\"}[6h])) / clamp_min(sum(increase(chat_compaction_summary_attached_total[6h])),1)",
          "legendFormat": "attached",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Tokens saved by compaction",
      "description": "Per-turn tokens NOT sent to the LLM because the transcript was compacted (full mean \u2212 context mean, 30m). Higher = more context budget reclaimed.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(chat_compaction_tokens_sum{kind=\"full\"}[30m]))/sum(rate(chat_compaction_tokens_count{kind=\"full\"}[30m]))",
          "legendFormat": "full transcript (mean)",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(chat_compaction_tokens_sum{kind=\"context\"}[30m]))/sum(rate(chat_compaction_tokens_count{kind=\"context\"}[30m]))",
          "legendFormat": "context sent (mean)",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(sum(rate(chat_compaction_tokens_sum{kind=\"full\"}[30m]))/sum(rate(chat_compaction_tokens_count{kind=\"full\"}[30m]))) - (sum(rate(chat_compaction_tokens_sum{kind=\"context\"}[30m]))/sum(rate(chat_compaction_tokens_count{kind=\"context\"}[30m])))",
          "legendFormat": "tokens SAVED",
          "refId": "C"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 11,
      "type": "row",
      "title": "Authorization \u2014 Cerbos structural gate",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 28
      }
    },
    {
      "id": 12,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "options": {
        "mode": "markdown",
        "content": "_Denials are healthy security events, not errors. Watch the allow/deny split, not just the allow rate._"
      }
    },
    {
      "id": 13,
      "type": "gauge",
      "title": "Cerbos allow rate",
      "description": "Share of Cerbos decisions that ALLOW (1h). Read alongside the split at right \u2014 a healthy system denies out-of-book access.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 31
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * sum(increase(conduit_authz_decisions_total{decision=\"ALLOW\"}[1h])) / clamp_min(sum(increase(conduit_authz_decisions_total[1h])),1)",
          "legendFormat": "allow %",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 14,
      "type": "bargauge",
      "title": "Allow vs deny (1h)",
      "description": "conduit_authz_decisions_total split by decision over the last hour.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 31
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(conduit_authz_decisions_total[1h])) by (decision)",
          "legendFormat": "{{decision}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Authz decisions by source",
      "description": "Decision rate split by policy source and decision (5m). Shows which layer is gating.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 31
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(conduit_authz_decisions_total[5m])) by (source, decision)",
          "legendFormat": "{{source}} {{decision}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 16,
      "type": "row",
      "title": "Agents at a glance \u2014 circuit-breaker health (detail in the Agents board)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 39
      }
    },
    {
      "id": 17,
      "type": "stat",
      "title": "Agents healthy",
      "description": "Count of agent circuit breakers CLOSED (serving normally).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 40
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count(conduit_circuit_breaker_state == 0)",
          "legendFormat": "closed",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 18,
      "type": "stat",
      "title": "Agents tripped",
      "description": "Count of agent circuit breakers OPEN or half-open. Good = 0.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 40
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "clamp_max(count(conduit_circuit_breaker_state > 0) or vector(0), 99)",
          "legendFormat": "tripped",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 19,
      "type": "state-timeline",
      "title": "Circuit-breaker state per agent",
      "description": "Live breaker state per agent over time (green closed / red open / yellow half-open).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 40
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              },
              {
                "color": "yellow",
                "value": 2
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
