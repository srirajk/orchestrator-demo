{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Conduit Chat BFF — Memory / Compaction guardrail metrics. summary_attached{attached=true}==0 is the canary for silent compaction breakage.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Memory / Compaction",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Fraction of assembled turns where the rolling summary was attached. A sustained value of 0 while turns are occurring signals silent compaction breakage.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "green", "value": 0.3 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(chat_compaction_summary_attached_total{attached=\"true\"}[5m]) / (rate(chat_compaction_summary_attached_total[5m]) > 0)",
          "legendFormat": "summary attached ratio"
        }
      ],
      "title": "Summary-Attached Ratio (GUARDRAIL — 0 = silent breakage)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Number of messages in the assembled context window sent to the gateway per turn (mean and p95).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(chat_compaction_context_messages_sum[5m]) / rate(chat_compaction_context_messages_count[5m])",
          "legendFormat": "mean messages"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(chat_compaction_context_messages_sum[5m]) / rate(chat_compaction_context_messages_count[5m])",
          "legendFormat": "p95 messages"
        }
      ],
      "title": "Context Window Size (messages / turn)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Tokens saved per turn = full transcript tokens − assembled context tokens. Higher = more savings from compaction.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(chat_compaction_tokens_sum{kind=\"full\"}[5m]) / rate(chat_compaction_tokens_count{kind=\"full\"}[5m])",
          "legendFormat": "mean full transcript tokens"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(chat_compaction_tokens_sum{kind=\"context\"}[5m]) / rate(chat_compaction_tokens_count{kind=\"context\"}[5m])",
          "legendFormat": "mean context tokens sent"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "(rate(chat_compaction_tokens_sum{kind=\"full\"}[5m]) / rate(chat_compaction_tokens_count{kind=\"full\"}[5m])) - (rate(chat_compaction_tokens_sum{kind=\"context\"}[5m]) / rate(chat_compaction_tokens_count{kind=\"context\"}[5m]))",
          "legendFormat": "tokens SAVED"
        }
      ],
      "title": "Tokens Saved by Compaction",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Latency of the fire-and-forget LLM summary generation call (p95) and error rate.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(chat_summary_generation_seconds_sum[5m]) / rate(chat_summary_generation_seconds_count[5m])",
          "legendFormat": "p50 latency"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "chat_summary_generation_seconds_max",
          "legendFormat": "p95 latency"
        }
      ],
      "title": "Summary Generation Latency (avg / max)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rate of summary generation errors (LLM non-2xx or exception in the background task).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(chat_summary_generation_errors_total[5m])",
          "legendFormat": "summary errors / sec"
        }
      ],
      "title": "Summary Generation Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Raw turn counter: summary attached vs not attached. The blue line (attached=true) must be non-zero when conversations are long enough to trigger compaction.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 15 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(chat_compaction_summary_attached_total{attached=\"true\"}[2m])",
          "legendFormat": "turns with summary attached (rate)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(chat_compaction_summary_attached_total{attached=\"false\"}[2m])",
          "legendFormat": "turns without summary (rate)"
        }
      ],
      "title": "Summary Attached Rate — raw counter (ZERO on top line = silent broken compaction)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["conduit", "chat", "compaction", "memory"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 2,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Conduit Chat — Memory / Compaction",
  "uid": "conduit-chat-compaction",
  "version": 1
}
