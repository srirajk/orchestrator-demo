# =============================================================================
# Meridian Gateway — Environment Configuration Template
# Copy to .env and fill in your values.
#
# LLM PROVIDER SETUP (pick one approach):
#
#   Option A — Z.AI GLM (default, recommended for demo):
#     Set ZAI_API_KEY. All three gateway LLM clients use it automatically.
#     Models default to: classifier=glm-4.5-flash, extractor=glm-4.5-flash, synthesizer=glm-4.6
#
#   Option B — OpenAI:
#     Set OPENAI_API_KEY, then override the per-client vars below.
#     Uncomment the OPENAI block under each client section.
#
#   Option C — Different provider per client:
#     Set MERIDIAN_LLM_*_BASE_URL + MERIDIAN_LLM_*_API_KEY + MERIDIAN_LLM_*_MODEL per client.
# =============================================================================

# ── Primary LLM key (Z.AI GLM — used by all 3 gateway clients unless overridden) ──
ZAI_API_KEY=your_zai_api_key_here

# ── Per-client overrides (optional — uncomment to switch a specific client) ───
# Intent Classifier  (fast model, low-latency classification)
# MERIDIAN_LLM_INTENT_CLASSIFIER_BASE_URL=https://api.openai.com/v1
# MERIDIAN_LLM_INTENT_CLASSIFIER_API_KEY=your_openai_key
# MERIDIAN_LLM_INTENT_CLASSIFIER_MODEL=gpt-4o-mini

# Entity Extractor  (fast model, entity reference extraction)
# MERIDIAN_LLM_ENTITY_EXTRACTOR_BASE_URL=https://api.openai.com/v1
# MERIDIAN_LLM_ENTITY_EXTRACTOR_API_KEY=your_openai_key
# MERIDIAN_LLM_ENTITY_EXTRACTOR_MODEL=gpt-4o-mini

# Answer Synthesizer  (most capable model, grounded streaming answer)
# MERIDIAN_LLM_SYNTHESIZER_BASE_URL=https://api.openai.com/v1
# MERIDIAN_LLM_SYNTHESIZER_API_KEY=your_openai_key
# MERIDIAN_LLM_SYNTHESIZER_MODEL=gpt-4o

# ── Mock Agents ───────────────────────────────────────────────────────────────
WEALTH_AGENT_HOST=wealth-http
WEALTH_AGENT_PORT=8081
SERVICING_AGENT_HOST=servicing-mcp
SERVICING_AGENT_PORT=8082

# ── Agent LLM — shared defaults (all 9 agents inherit these) ─────────────────
WEALTH_AGENT_LLM_BASE_URL=https://api.z.ai/api/paas/v4
WEALTH_AGENT_LLM_API_KEY=${ZAI_API_KEY}
WEALTH_AGENT_LLM_MODEL=glm-4.5-flash

SERVICING_AGENT_LLM_BASE_URL=https://api.z.ai/api/paas/v4
SERVICING_AGENT_LLM_API_KEY=${ZAI_API_KEY}
SERVICING_AGENT_LLM_MODEL=glm-4.5-flash
# LLM call timeout in seconds for servicing (MCP) agents
SERVICING_AGENT_LLM_TIMEOUT_S=30

# ── Fan-out deadline ──────────────────────────────────────────────────────────
# Wall-clock limit for the full agent fan-out (all nodes must settle within this)
MERIDIAN_FANOUT_DEADLINE_MS=35000

# ── LibreChat auth ────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_hex_string
JWT_REFRESH_SECRET=change_me_to_another_random_hex_string

# ── OIDC / SSO ────────────────────────────────────────────────────────────────
# OIDC_CLIENT_SECRET is the shared secret between LibreChat and the IAM service.
# Both sides must agree on this value.
# The IAM service registers a client with id="meridian-librechat" using this secret.
# LibreChat presents this secret when exchanging the authorization code for tokens.
# Change in production — use a long random string (e.g. openssl rand -hex 32).
OIDC_CLIENT_SECRET=meridian-client-secret-dev

# OPENID_SESSION_SECRET is the LibreChat session store signing key — separate from OIDC.
OPENID_SESSION_SECRET=meridian-openid-session-secret-dev

# Redirect URI registered in the IAM service for the LibreChat OIDC client.
# Must match the DOMAIN_SERVER + OPENID_CALLBACK_URL that LibreChat sends in the auth code request.
IAM_LIBRECHAT_REDIRECT_URI=http://localhost:3080/oauth/openid/callback

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme

# ── IAM Service (Java Spring Boot — replaces Python user-mgmt) ────────────────
IAM_ADMIN_PASSWORD=Meridian@2024
# Password for seeded test users (rm_jane, rm_diaz, rm_carlos, etc.) — used by E2E tests.
IAM_USER_PASSWORD=Meridian@2024
CERBOS_AUTHZ_ENABLED=true
# Mandated JWT claim: tenant_id. Comes from principal.tenant_id in the database.
# This is the fallback only — every seeded principal already has tenant_id='default'.
# To onboard a new tenant: add a row to the tenants table and set principal.tenant_id accordingly.
MERIDIAN_IAM_DEFAULT_TENANT_ID=default
# IAM_ISSUER_URL is the OIDC issuer — must be reachable by browsers AND LibreChat (inside Docker).
# Mac/Windows (Docker Desktop): host.docker.internal resolves to 127.0.0.1 on both sides.
# Linux: replace with your machine's LAN IP (e.g. http://192.168.1.10:8084).
IAM_ISSUER_URL=http://host.docker.internal:8084

# ── Postgres (IAM service primary DB) ────────────────────────────────────────
# Change in non-dev environments. Must match docker-compose postgres service.
POSTGRES_PASSWORD=meridian_dev

# ── MinIO (S3-compatible blob store for Langfuse) ────────────────────────────
# Change in non-dev environments. Must be consistent across minio + langfuse services.
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniosecret

# ── ClickHouse (columnar trace store for Langfuse v3) ────────────────────────
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=clickhouse

# ── Langfuse DB (dedicated Postgres instance) ────────────────────────────────
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=langfuse

# ── Langfuse application secrets ─────────────────────────────────────────────
# Generate production values with: openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=meridian-langfuse-nextauth-secret
LANGFUSE_SALT=meridian-langfuse-salt-changeme
LANGFUSE_ENCRYPTION_KEY=fb53c0e05d8044c734a1b20044e89f6c33783e489635b6e4bba69b231ce47bd8

# ── Langfuse project API keys (pre-seeded org/project/admin) ─────────────────
# Used by the gateway and eval-worker to authenticate to Langfuse.
LANGFUSE_PROJECT_PUBLIC_KEY=pk-lf-meridian-public
LANGFUSE_PROJECT_SECRET_KEY=sk-lf-meridian-secret
LANGFUSE_ADMIN_PASSWORD=changeme

# ── E2E / Admin UI ───────────────────────────────────────────────────────────
ADMIN_UI_URL=http://localhost:5180
