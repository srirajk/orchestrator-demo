# ── Gateway ──────────────────────────────────────────────────────────────────
# Z.AI GLM API key — used by the gateway for input extraction and answer synthesis.
# Get one at https://api.z.ai
ZAI_API_KEY=your_zai_api_key_here

# ── LibreChat auth ────────────────────────────────────────────────────────────
# Generate strong random values for production:
#   openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_hex_string
JWT_REFRESH_SECRET=change_me_to_another_random_hex_string
