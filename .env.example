# ── Gateway ──────────────────────────────────────────────────────────────────
# Z.AI GLM API key — used by the gateway for input extraction and answer synthesis.
# Get one at https://api.z.ai
ZAI_API_KEY=your_zai_api_key_here

# Model selection per pipeline stage (all default to glm-4.5-flash)
# MERIDIAN_LLM_INTENT_MODEL=glm-4.5-flash
# MERIDIAN_LLM_EXTRACTION_MODEL=glm-4.5-flash
# MERIDIAN_LLM_SYNTHESIS_MODEL=glm-4.5-flash   # upgrade to glm-4.6 for paid plan

# Set to true to stream the model's chain-of-thought as a blockquote before each answer
# MERIDIAN_LLM_SHOW_REASONING=false

# Conversation session TTL in seconds (default 30 minutes)
# MERIDIAN_SESSION_TTL_SECONDS=1800

# ── LibreChat auth ────────────────────────────────────────────────────────────
# Generate strong random values for production:
#   openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_hex_string
JWT_REFRESH_SECRET=change_me_to_another_random_hex_string
