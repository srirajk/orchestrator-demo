{
  "sub_domain_id": "private-banking",
  "display_name": "Private Banking",
  "parent_domain": "wealth-management",
  "resource_scoped": true,

  "entity_types": [
    {
      "key": "relationship_id",
      "display": "client relationship",
      "id_pattern": "REL-\\d{5}",
      "resolve_type": "relationship",
      "required": true
    },
    {
      "key": "time_period",
      "display": "reporting period",
      "id_pattern": "(Q[1-4]\\s+\\d{4}|YTD|QTD|MTD)",
      "resolve_type": "time_period",
      "required": false,
      "default": "most recent quarter"
    },
    {
      "key": "fund_id",
      "display": "fund or investment strategy",
      "id_pattern": "FND-\\w+",
      "resolve_type": "fund",
      "required": false
    }
  ],

  "required_context": ["relationship_id"],

  "clarification_schema": {
    "relationship_id": {
      "question": "Which client relationship are you asking about?",
      "options_source": "discover",
      "priority": 1
    },
    "time_period": {
      "question": "Which period would you like to review?",
      "options_source": "agent_derived",
      "default": "most recent quarter",
      "priority": 2
    }
  },

  "agents": [
    "acme.wealth.holdings",
    "acme.wealth.performance",
    "acme.wealth.risk_profile",
    "acme.wealth.goal_planning"
  ]
}
