{
  "sub_domain_id": "custody-operations",
  "display_name": "Custody Operations",
  "parent_domain": "asset-servicing",
  "resource_scoped": false,
  "entity_types": [
    {
      "key": "fund_id",
      "extract_as": "fund_reference",
      "kind": "resolvable",
      "display": "fund or portfolio",
      "id_pattern": "FND-\\w+",
      "resolve_type": "fund",
      "required": false
    },
    {
      "key": "settlement_id",
      "extract_as": "settlement_id",
      "kind": "literal",
      "display": "settlement or trade reference",
      "id_pattern": "SETT-\\w+",
      "required": false
    },
    {
      "key": "security_id",
      "extract_as": "security_id",
      "kind": "literal",
      "display": "security or ISIN",
      "id_pattern": "[A-Z]{2}[A-Z0-9]{10}|[A-Z]{2,5}",
      "required": false
    }
  ],
  "required_context": [],
  "agents": [
    "meridian.servicing.custody_positions",
    "meridian.servicing.settlement_status"
  ],
  "messages": {
    "capability_unavailable": "That capability isn't available to you right now."
  }
}
