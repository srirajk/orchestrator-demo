{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conduit.dev/schemas/sub-domain-manifest.schema.json",
  "title": "Conduit Sub-Domain Manifest",
  "description": "Contract for registry/domains/<domain>/<sub-domain>.json. Sub-domain manifests declare entity context, clarification copy, coverage scoping, and agent membership.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sub_domain_id",
    "display_name",
    "parent_domain",
    "resource_scoped",
    "entity_types",
    "required_context",
    "agents"
  ],
  "properties": {
    "sub_domain_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "display_name": { "type": "string", "minLength": 1 },
    "parent_domain": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "resource_scoped": { "type": "boolean" },
    "entity_types": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "extract_as", "kind", "display", "required"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "extract_as": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["resolvable", "literal", "list"] },
          "display": { "type": "string", "minLength": 1 },
          "id_pattern": { "type": "string", "minLength": 1 },
          "resolve_type": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "default": { "type": ["string", "number", "boolean"] }
        }
      }
    },
    "required_context": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "denial_messages": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "messages": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "clarification_schema": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "options_source", "priority"],
        "properties": {
          "question": { "type": "string", "minLength": 1 },
          "options_source": {
            "type": "string",
            "enum": ["discover", "agent_derived", "none", "principal_book"]
          },
          "priority": { "type": "integer", "minimum": 1 },
          "default": { "type": ["string", "number", "boolean"] }
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(\\.[a-z0-9_]+)+$"
      }
    }
  }
}
