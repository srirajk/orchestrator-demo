        "how concentrated is this portfolio",
        "risk tolerance for the relationship",
        "any concentration flags on this account"
      ],
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json"
      ]
    }
  ],
  "constraints": {
    "access_mode": "read",
    "data_classification": "confidential-pii",
    "sla_timeout_ms": 30000
  },
  "io": {
    "consumes": [
      { "entity": "relationship_id", "required": true }
    ],
    "produces": [
      { "name": "risk_profile", "type": "wealth.risk_profile" }
    ]
