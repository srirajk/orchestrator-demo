{
  "agent_id": "acme.wealth.risk_profile",
  "name": "Wealth Risk Profile",
  "description": "Returns risk tolerance assessment and concentration flags for a given wealth management relationship. Accepts relationship_id as the primary key.",
  "version": "1.0.0",
  "provider": {
    "organization": "Meridian Demo Bank"
  },
  "domain": "wealth-management",
  "audience": "segment",
  "sub_domain": "private-banking",
  "max_response_tokens": 2000,
  "protocol": "http",
  "connection": {
    "openapi_url": "http://wealth-http:8081/openapi.json",
    "operation_id": "get_risk_profile_risk_profile_get"
  },
  "capabilities": {
    "streaming": false,
    "pushNotifications": false
  },
  "skills": [
    {
      "id": "get_risk_profile",
      "name": "get_risk_profile",
