{
  "agent_id": "meridian.servicing.trade_penalty",
  "name": "Asset Servicing Failed Trade Penalty",
  "description": "Computes CSDR-style cash penalty aging for each failed settlement item selected from settlement status.",
  "version": "1.0.0",
  "provider": {
    "organization": "Meridian Demo Bank"
  },
  "domain": "asset-servicing",
  "audience": "segment",
  "sub_domain": "custody-operations",
  "max_response_tokens": 2000,
  "protocol": "mcp",
  "connection": {
    "server_url": "http://servicing-mcp:8082/mcp",
    "tool": "calculate_trade_penalty",
    "transport": "streamable"
  },
  "capabilities": {
    "streaming": false,
    "pushNotifications": false
  },
  "skills": [
    {
      "id": "calculate_trade_penalty",
      "name": "calculate_trade_penalty",
      "description": "Calculate per-failed-trade CSDR cash-penalty exposure and aging from settlement status records.",
      "tags": [
        "settlements",
        "failed-trades",
        "csdr",
        "cash-penalty",
        "map-iteration",
        "asset-servicing"
      ],
      "examples": [
        "itemize failed trade rows one trade at a time",
        "list every failed trade as separate penalty calculation rows",
        "produce a per-trade penalty table for failed trade items",
        "map each failed trade item into one penalty row",
        "show skipped failed trade rows when the map cap is reached",
        "return trade id, security, age days, and penalty amount per row",
        "itemize per-failed-trade penalty details",
        "row-by-row failed trade penalty listing"
      ],
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json"
      ]
    }
  ],
  "constraints": {
    "access_mode": "read",
    "data_classification": "confidential",
    "sla_timeout_ms": 30000
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "trade_id": {
        "type": "string"
      },
      "security": {
        "type": "string"
      },
      "isin": {
        "type": "string"
      },
      "settle_date": {
        "type": "string"
      },
      "as_of_date": {
        "type": "string"
      },
      "amount": {
        "type": "number"
      },
      "side": {
        "type": "string"
      },
      "reason": {
        "type": "string"
      },
      "age_days": {
        "type": "integer"
      },
      "csdr_daily_penalty_bps": {
        "type": "number"
      },
      "estimated_daily_penalty_usd": {
        "type": "number"
      },
      "estimated_accrued_penalty_usd": {
        "type": "number"
      },
      "mandatory_buy_in_active": {
        "type": "boolean"
      },
      "agent_narrative": {
        "type": "string"
      }
    },
    "required": [
      "trade_id",
      "security",
      "settle_date",
      "as_of_date",
      "amount",
      "side",
      "age_days",
      "csdr_daily_penalty_bps",
      "estimated_daily_penalty_usd",
      "estimated_accrued_penalty_usd",
      "mandatory_buy_in_active"
    ]
  },
  "io": {
    "consumes": [
      {
        "from": "servicing.settlement_status",
        "required": true,
        "select": "{'failed': has(input.failed) ? input.failed : null}"
      }
    ],
    "map": {
      "over": "input.failed",
      "item_select": "{'trade_id': has(item.trade_id) ? item.trade_id : null, 'security': has(item.security) ? item.security : null, 'isin': has(item.isin) ? item.isin : null, 'settle_date': has(item.settle_date) ? item.settle_date : null, 'amount': has(item.amount) ? item.amount : null, 'side': has(item.side) ? item.side : null, 'as_of_date': has(item.as_of_date) ? item.as_of_date : null, 'reason': has(item.reason) ? item.reason : null, 'fail_item': has(item.fail_item) ? item.fail_item : null}",
      "max_items": 2,
      "max_concurrency": 2
    },
    "produces": [
      {
        "name": "trade_penalties",
        "type": "servicing.trade_penalties"
      }
    ]
  }
}
