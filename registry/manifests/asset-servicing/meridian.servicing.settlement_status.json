{
  "agent_id": "meridian.servicing.settlement_status",
  "name": "Asset Servicing Settlement Status",
  "description": "Returns pending and failed settlement records for a given relationship. Accepts relationship_id as the primary key. Accessed via MCP tool over Streamable HTTP transport.",
  "version": "1.0.0",
  "provider": {
    "organization": "Meridian Demo Bank"
  },
  "domain": "asset-servicing",
  "audience": "segment",
  "sub_domain": "custody-operations",
  "max_response_tokens": 2000,
  "protocol": "mcp",
  "connection": {
    "server_url": "http://servicing-mcp:8082/mcp",
    "tool": "get_settlements",
    "transport": "streamable"
  },
  "capabilities": {
    "streaming": false,
    "pushNotifications": false
  },
  "skills": [
    {
      "id": "get_settlements",
      "name": "get_settlements",
      "description": "Retrieve pending and failed trade settlements for a given asset servicing relationship.",
      "tags": [
        "settlements",
        "pending",
        "failed-trades",
        "trade-status",
        "asset-servicing"
      ],
      "examples": [
        "any pending settlements on this account",
        "failed trades for the relationship",
        "settlement status for this client",
        "unsettled trades I should know about",
        "pending settlements for this relationship",
        "what are the outstanding trade settlements on the servicing side",
        "show me pending and failed settlements for this relationship",
        "which trades have not settled yet for this custody account",
        "list the failed and pending trade breaks for this relationship"
      ],
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json"
      ]
    }
  ],
  "constraints": {
    "access_mode": "read",
    "data_classification": "confidential",
    "sla_timeout_ms": 30000
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "relationship_id": {
        "type": "string"
      },
      "pending": {
        "type": "array",
        "items": {
          "type": "object"
        }
      },
      "failed": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "trade_id": {
              "type": "string"
            },
            "security": {
              "type": "string"
            },
            "isin": {
              "type": "string"
            },
            "settle_date": {
              "type": "string"
            },
            "as_of_date": {
              "type": "string"
            },
            "amount": {
              "type": "number"
            },
            "side": {
              "type": "string"
            },
            "reason": {
              "type": "string"
            },
            "fail_item": {
              "type": "boolean"
            }
          },
          "required": [
            "trade_id",
            "security",
            "settle_date",
            "as_of_date",
            "amount",
            "side"
          ]
        }
      },
      "as_of_date": {
        "type": "string"
      },
      "agent_narrative": {
        "type": "string"
      }
    },
    "required": [
      "relationship_id",
      "pending",
      "failed",
      "as_of_date"
    ]
  },
  "io": {
    "consumes": [
      {
        "entity": "relationship_id",
        "required": true
      }
    ],
    "produces": [
      {
        "name": "settlement_status",
        "type": "servicing.settlement_status"
      }
    ]
  }
}
