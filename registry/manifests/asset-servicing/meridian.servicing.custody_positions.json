{
  "agent_id": "meridian.servicing.custody_positions",
  "name": "Asset Servicing Custody Positions",
  "description": "Returns custody holdings broken down by custodian for a given relationship. Accepts relationship_id as the primary key. Accessed via MCP tool over SSE transport.",
  "version": "1.0.0",
  "provider": {
    "organization": "Meridian Demo Bank"
  },
  "domain": "asset-servicing",
  "audience": "segment",
  "sub_domain": "custody-operations",
  "max_response_tokens": 2000,
  "protocol": "mcp",
  "connection": {
    "server_url": "http://servicing-mcp:8082/sse",
    "tool": "get_custody_positions",
    "transport": "sse"
  },
  "capabilities": {
    "streaming": false,
    "pushNotifications": false
  },
  "skills": [
    {
      "id": "get_custody_positions",
      "name": "get_custody_positions",
      "description": "Retrieve holdings broken down by custodian for a given asset servicing relationship.",
      "tags": [
        "custody",
        "positions",
        "custodian",
        "holdings",
        "asset-servicing"
      ],
      "examples": [
        "custody holdings for the relationship",
        "what's held at the custodian",
        "custody positions for this account",
        "where are these assets custodied"
      ],
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json"
      ]
    }
  ],
  "constraints": {
    "access_mode": "read",
    "data_classification": "confidential",
    "sla_timeout_ms": 30000
  },
  "io": {
    "consumes": [
      { "entity": "relationship_id", "required": true }
    ],
    "produces": [
      { "name": "custody_positions", "type": "servicing.custody_positions" }
    ]
  }
}
