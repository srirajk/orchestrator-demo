{
  "sub_domain_id": "custody-operations",
  "display_name": "Custody Operations",
  "parent_domain": "asset-servicing",
  "resource_scoped": false,

  "entity_types": [
    {
      "key": "relationship_id",
      "extract_as": "relationship_reference",
      "kind": "resolvable",
      "display": "servicing relationship",
      "id_pattern": "REL-\\w+",
      "resolve_type": "relationship",
      "required": false
    },
    {
      "key": "fund_id",
      "extract_as": "fund_reference",
      "kind": "resolvable",
      "display": "fund or portfolio",
      "id_pattern": "FND-\\w+",
      "resolve_type": "fund",
      "required": false
    },
    {
      "key": "settlement_id",
      "extract_as": "settlement_id",
      "kind": "literal",
      "display": "settlement or trade reference",
      "id_pattern": "SETT-\\w+",
      "required": false
    },
    {
      "key": "security_id",
      "extract_as": "security_id",
      "kind": "literal",
      "display": "security or ISIN",
      "id_pattern": "[A-Z]{2}[A-Z0-9]{10}|[A-Z]{2,5}",
      "required": false
    }
  ],

  "required_context": [],

  "agents": [
    "acme.servicing.custody_positions",
    "acme.servicing.settlement_status",
    "acme.servicing.settlement_risk"
  ]
}
