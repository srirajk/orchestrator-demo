{
  "domain_id": "asset-servicing",
  "display_name": "Asset Servicing",
  "memory_compaction": {
    "envelope_version": "context-envelope.v1",
    "must_preserve": ["domain", "sub_domain"],
    "can_drop": ["raw_agent_outputs"],
    "summary_policy": {
      "owner": "memory-service",
      "max_summary_tokens": 500,
      "refresh_after_turns": 10,
      "ledger_retention_days": 90,
      "include_runtime_events": [
        "gateway.agents_resolved",
        "gateway.agent_completed",
        "gateway.response_completed"
      ],
      "redact_fields": ["raw_agent_outputs"]
    }
  }
}
