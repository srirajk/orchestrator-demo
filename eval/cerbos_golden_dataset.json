{
  "version": "1.0.0",
  "description": "Golden dataset for Cerbos policy validation. Each case is a CheckResources scenario with an expected ALLOW or DENY. Run against the live Cerbos PDP to score any set of deployed policies.",
  "cerbos_url": "http://localhost:3594",
  "cases": [
    {
      "id": "AGT-001",
      "description": "chat_user in wealth (internal tier) invokes internal-classified wealth agent — baseline happy path; classification gate allows (internal >= internal)",
      "tags": ["agent", "abac", "chat_user", "classification", "allow"],
      "principal": {
        "id": "rm_jane",
        "roles": ["chat_user"],
        "attr": { "tenant_id": "default", "segments": { "wealth": "internal" } }
      },
      "resource": {
        "kind": "agent", "id": "wealth-holdings",
        "attr": { "domain": "wealth-management", "audience": "segment", "access_mode": "read", "data_classification": "internal" }
      },
      "action": "invoke",
      "expected": "ALLOW"
    },
    {
      "id": "AGT-002",
      "description": "chat_user holding only the internal tier in wealth cannot invoke a confidential-classified wealth agent — classification gate denies (internal < confidential)",
      "tags": ["agent", "abac", "chat_user", "classification", "deny"],
      "principal": {
        "id": "rm_junior",
        "roles": ["chat_user"],
        "attr": { "tenant_id": "default", "segments": { "wealth": "internal" } }
      },
