{
  "version": "1.0.0",
  "description": "Golden dataset for Cerbos policy validation. Each case is a CheckResources scenario with an expected ALLOW or DENY. Run against the live Cerbos PDP to score any set of deployed policies.",
  "cerbos_url": "http://localhost:3594",
  "cases": [
    {
      "id": "AGT-001",
      "description": "RM invokes internal-classified wealth agent — baseline happy path",
      "tags": ["agent", "rm", "classification", "allow"],
      "principal": {
        "id": "rm_jane",
        "roles": ["relationship_manager"],
        "attr": { "tenant_id": "default", "segments": ["wealth"], "clearance": "1", "book": ["REL-00042"] }
      },
      "resource": {
        "kind": "agent", "id": "wealth-holdings",
        "attr": { "domain": "wealth-management", "is_mutating": false, "data_classification": "internal" }
      },
      "action": "invoke",
      "expected": "ALLOW"
    },
