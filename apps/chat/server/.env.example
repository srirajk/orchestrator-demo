# MongoDB
MONGODB_URI=mongodb://mongodb:27017/conduitchat

# Conduit Gateway (OpenAI-compatible)
GATEWAY_BASE=http://gateway:8080

# OIDC / Axiom IAM
OIDC_ISSUER=http://iam-service:8084
OIDC_CLIENT_ID=conduit-chat
OIDC_CLIENT_SECRET=changeme
OIDC_REDIRECT_URI=http://localhost:8095/api/auth/callback

# Session
SESSION_SECRET=change-me-in-production

# Chat context window tuning
CHAT_RECENT_MESSAGES=8
CHAT_SUMMARY_AFTER=12
CHAT_SUMMARY_MAX_TOKENS=150

# MinIO (file uploads) — STUBBED, not implemented
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=conduit-chat-files

# Server
PORT=8095
NODE_ENV=development
